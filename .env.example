# Vercel AI Gateway (not required on a linked Vercel deployment using OIDC)
AI_GATEWAY_API_KEY=

# Sendblue. In production the API secret is read from this Vercel Connect UID.
SENDBLUE_CONNECTOR_UID=
SENDBLUE_API_KEY=
SENDBLUE_FROM_NUMBER=
SENDBLUE_WEBHOOK_SECRET=

# Only this E.164 number is allowed to talk to Burn Mode.
BURN_MODE_PHONE_NUMBER=

# Required in production for webhook dedupe, locks, opt-out state, and approvals.
REDIS_URL=

# Local development fallback only. Do not set this when Connect is configured.
SENDBLUE_API_SECRET=

# Private inbound Eve HTTP access for a trusted client
BURN_MODE_USERNAME=christopher
BURN_MODE_PASSWORD=

# Optional Mac bridge for calendar, reminders, and health logs.
BURN_MODE_BRIDGE_URL=http://127.0.0.1:8787
BURN_MODE_BRIDGE_TOKEN=
