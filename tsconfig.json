{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "agent/**/*.ts",
    "evals/**/*.ts",
    "tests/**/*.ts",
    ".eve/**/*.d.ts"
  ]
}
